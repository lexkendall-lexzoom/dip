# Supabase bootstrap / sync settings
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Direct Postgres connection string (preferred in CI/local migrations)
DATABASE_URL=

# Optional: database-url or sql-over-http
SUPABASE_BOOTSTRAP_MODE=database-url

# Discovery / enrichment
OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
OVERPASS_TIMEOUT_MS=25000
OVERPASS_RETRY_COUNT=3
# GOOGLE_PLACES_API_KEY and ANTHROPIC_API_KEY are stored in Supabase Vault.
# The enrich-nyc-venues.js script reads them via vault.decrypted_secrets
# using the SUPABASE_URL + SUPABASE_SERVICE_KEY credentials above.

# Review evidence ingestion (tier 3)
OUTSCRAPER_API_KEY=
REVIEW_FIXTURE_PATH=
