# Supabase bootstrap settings
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Direct Postgres connection string (preferred in CI/local migrations)
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# Optional: database-url or sql-over-http
SUPABASE_BOOTSTRAP_MODE=database-url
