<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ title | default("Dip Days") }}</title>
  {% if description %}<meta name="description" content="{{ description }}"/>{% endif %}
  {% if canonical %}<link rel="canonical" href="{{ canonical }}"/>{% endif %}
  <meta property="og:title" content="{{ og_title | default(title) }}"/>
  {% if description %}<meta property="og:description" content="{{ description }}"/>{% endif %}
  <meta property="og:type" content="{{ og_type | default('website') }}"/>
  {% if canonical %}<meta property="og:url" content="{{ canonical }}"/>{% endif %}
  <meta property="og:image" content="{{ social_image | default('https://dipdays.com/og-image.png') }}"/>
  <meta name="twitter:card" content="{{ twitter_card | default('summary') }}"/>
  <meta name="twitter:image" content="{{ social_image | default('https://dipdays.com/og-image.png') }}"/>
  <!-- PWA -->
  <link rel="manifest" href="/manifest.json"/>
  <meta name="theme-color" content="#0b7c78"/>
  <meta name="mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
  <meta name="apple-mobile-web-app-title" content="Dip Days"/>
  <link rel="apple-touch-icon" href="/icons/icon.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Playfair+Display:ital,wght@0,500;1,400;1,500&display=swap"/>
  {% block head %}{% endblock %}
</head>
<body>
  {% block body %}{{ content | safe }}{% endblock %}
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', function() {
        navigator.serviceWorker.register('/sw.js');
      });
    }
  </script>
</body>
</html>
