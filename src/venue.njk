---
pagination:
  data: directory.venuePages
  size: 1
  alias: page
permalink: "{{ page.path }}"
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{{ page.name }} in {{ page.cityName }} | DipDays</title>
  <meta name="description" content="{{ page.name }} is listed in the DipDays directory for {{ page.cityName }}." />
  <script type="application/ld+json">{{ page.schema | json }}</script>
</head>
<body>
  <h1>{{ page.name }}</h1>
  <p>{{ page.cityName }} · {{ page.categoryName }}</p>
  {% if page.website %}<p><a href="{{ page.website }}">Official website</a></p>{% endif %}

  <h2>Internal links</h2>
  <ul>
    <li><a href="{{ page.linkGraph.city.path }}">{{ page.linkGraph.city.name }} page</a>{% if not page.linkGraph.city.indexable %} (noindex){% endif %}</li>
    <li><a href="{{ page.linkGraph.category.path }}">{{ page.linkGraph.category.name }} category</a>{% if not page.linkGraph.category.indexable %} (noindex){% endif %}</li>
    {% if page.linkGraph.bathingStyle %}
    <li><a href="{{ page.linkGraph.bathingStyle.path }}">{{ page.linkGraph.bathingStyle.name }} in {{ page.cityName }}</a>{% if not page.linkGraph.bathingStyle.indexable %} (noindex){% endif %}</li>
    {% endif %}
    {% for amenity in page.linkGraph.amenities %}
    <li><a href="{{ amenity.path }}">{{ amenity.name }}</a>{% if not amenity.indexable %} (noindex){% endif %}</li>
    {% endfor %}
  </ul>
</body>
</html>
