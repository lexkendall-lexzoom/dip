---
pagination:
  data: venues
  size: 1
  alias: item
permalink: "/{{ item.citySlug }}/{{ item.venue.slug | default(item.fileSlug) }}/"
---
{%- set v = item.venue -%}
{%- set seo = item.seo -%}
{%- set citySlug = item.citySlug -%}
{%- set venueSlug = v.slug | default(item.fileSlug) -%}
{%- set dipScore = v.score | default("Coming soon") -%}
{%- set audienceRating = v.audience_rating | default(v.audienceRating) | default(v.rating) | default("Not yet rated") -%}
{%- set rawRitualTags = v.ritual_tags | default(v.tags) | default(v.rituals) | default([]) -%}
{%- set ritualTags = [] -%}
{%- for tag in rawRitualTags -%}
  {%- set normalizedTag = tag.tag | default(tag.ritual_tag) | default(tag) -%}
  {%- if normalizedTag -%}{%- set ritualTags = ritualTags.concat([normalizedTag]) -%}{%- endif -%}
{%- endfor -%}
{%- set editorialSummary = v.editorial_summary | default(v.review) | default("Editorial summary coming soon.") -%}
{%- set dayPassPrice = v.day_pass_price | default(v.price) | default("—") -%}
{%- set membershipPrice = v.membership_price | default("—") -%}
{%- set openingHours = v.opening_hours | default(v.hours) | default("Hours unavailable") -%}
{%- set bookingLink = v.booking_link | default(v.booking_url) | default(v.website_url) -%}
{%- set latitude = v.latitude | default(v.lat) | default(v.coordinates.lat) -%}
{%- set longitude = v.longitude | default(v.lng) | default(v.coordinates.lng) -%}
{%- set instagramEmbeds = v.instagram_embeds | default(v.instagram_posts) | default([]) -%}
{%- set related = [] -%}
{%- set ritualNeedles = ritualTags | join('|') | lower -%}
{%- for candidate in venues -%}
  {%- if candidate.citySlug == citySlug and (candidate.venue.slug | default(candidate.fileSlug)) != venueSlug -%}
    {%- set candidateVenue = candidate.venue -%}
    {%- set rawCandidateTags = candidateVenue.ritual_tags | default(candidateVenue.tags) | default(candidateVenue.rituals) | default([]) -%}
    {%- set candidateTags = [] -%}
    {%- for tag in rawCandidateTags -%}
      {%- set normalizedTag = tag.tag | default(tag.ritual_tag) | default(tag) -%}
      {%- if normalizedTag -%}{%- set candidateTags = candidateTags.concat([normalizedTag]) -%}{%- endif -%}
    {%- endfor -%}
    {%- set candidateTagBlob = candidateTags | join('|') | lower -%}
    {%- set hasSimilarRitual = ritualNeedles and candidateTagBlob and (ritualNeedles in candidateTagBlob or candidateTagBlob in ritualNeedles) -%}
    {%- if hasSimilarRitual or ritualTags.length == 0 -%}{%- set related = related.concat([candidate]) -%}{%- endif -%}
  {%- endif -%}
{%- endfor -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ seo.title | default(v.name + " | Dip") }}</title>
  <meta name="description" content="{{ seo.description | default(editorialSummary | truncate(155, true)) }}" />
  <link rel="canonical" href="https://dipdays.com/{{ citySlug }}/{{ venueSlug }}/" />
  <meta property="og:title" content="{{ seo.title | default(v.name + ' Review | Dip') }}" />
  <meta property="og:description" content="{{ seo.description | default(editorialSummary | truncate(155, true)) }}" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content="https://dipdays.com/{{ citySlug }}/{{ venueSlug }}/" />
  {% if seo.social_image %}<meta property="og:image" content="{{ seo.social_image | assetUrl }}" />{% endif %}
  <meta name="twitter:card" content="summary_large_image" />
  <script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@graph":[
      {
        "@type":"Place",
        "name":{{ v.name | json }},
        "url":{{ ("https://dipdays.com/" + citySlug + "/" + venueSlug + "/") | json }},
        {% if seo.social_image or v.hero_image %}"image":{{ (seo.social_image | default(v.hero_image) | assetUrl) | json }},{% endif %}
        "address":{"@type":"PostalAddress","addressLocality":{{ v.city | default('') | json }}},
        {% if latitude and longitude %}"geo":{"@type":"GeoCoordinates","latitude":{{ latitude | json }},"longitude":{{ longitude | json }}},{% endif %}
        "aggregateRating":{"@type":"AggregateRating","ratingValue":{{ audienceRating | json }},"bestRating":"5"},
        "additionalType":"https://schema.org/WellnessFacility"
      },
      {
        "@type":"TouristAttraction",
        "name":{{ v.name | json }},
        "touristType":"Wellness traveler",
        "isPartOf":{{ v.city | default('') | json }}
      },
      {
        "@type":"WellnessFacility",
        "name":{{ v.name | json }},
        "description":{{ editorialSummary | truncate(220, true) | json }},
        "review":{"@type":"Review","reviewBody":{{ editorialSummary | truncate(220, true) | json }},"reviewRating":{"@type":"Rating","bestRating":"10","ratingValue":{{ dipScore | json }}}}
      }
    ]
  }
  </script>
  <link rel="stylesheet" href="/fonts/fonts.css"/>
  <style>
    :root{--ink:#101010;--muted:#6f6a63;--page:#f5f2eb;--card:#fffdf8;--line:#ded8cc;--teal:#0b7c78;--font-sans:'Syne',ui-sans-serif,system-ui;--font-serif:'Playfair Display',serif}
    *{box-sizing:border-box} body{margin:0;background:var(--page);color:var(--ink);font-family:var(--font-sans)}
    .shell{max-width:1200px;margin:0 auto;padding:24px 18px 70px}.panel{background:var(--card);border:1px solid var(--line);padding:18px}
    .back{display:inline-block;margin-bottom:16px;color:var(--teal);font-size:11px;letter-spacing:.14em;text-transform:uppercase;text-decoration:none;font-weight:700}
    .hero-section{display:grid;grid-template-columns:1.2fr .8fr;gap:18px}.hero-image{aspect-ratio:16/10;overflow:hidden;background:#d8d8d8}
    .hero-image img{width:100%;height:100%;object-fit:cover;display:block}h1{margin:0;font-size:clamp(2rem,3vw,3rem)}.city{color:var(--muted)}
    .ratings-block{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:14px 0}.metric{padding:10px;border:1px solid var(--line)}.value{font-size:1.2rem;font-weight:700}
    .tags{display:flex;flex-wrap:wrap;gap:8px}.tag{border:1px solid var(--line);padding:4px 8px;font-size:.8rem;text-transform:uppercase;letter-spacing:.08em}
    .eyebrow{font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:10px}
    .gallery-wrap{margin-top:18px}.gallery-track{display:flex;gap:12px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch}
    .gallery-card{min-width:min(80vw,380px);scroll-snap-align:start;background:#eee;aspect-ratio:4/3}.gallery-card img,.gallery-card iframe{width:100%;height:100%;object-fit:cover;border:none}
    .layout{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:18px}.copy{font-family:var(--font-serif);line-height:1.6}
    .ritual-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}.ritual-item{border:1px solid var(--line);padding:10px}
    .pricing{display:grid;grid-template-columns:1fr 1fr;gap:10px}.price-item{border:1px solid var(--line);padding:10px}.cta{display:inline-block;margin-top:12px;padding:10px 14px;background:#111;color:#fff;text-decoration:none}
    .map-frame{width:100%;height:320px;border:0}.cards{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}.card{display:block;border:1px solid var(--line);padding:12px;text-decoration:none;color:inherit}
    @media (max-width:980px){.hero-section,.layout,.ratings-block,.ritual-grid,.pricing,.cards{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <main class="shell">
    <a class="back" href="/#venue=/{{ citySlug }}/{{ venueSlug }}/">&#8592; Back to Dip directory</a>
    {% include "components/HeroSection.njk" %}
    {% include "components/ImageGallery.njk" %}
    <section class="layout">
      {% include "components/EditorialSummary.njk" %}
      {% include "components/RitualExperience.njk" %}
    </section>
    <section class="layout">
      <article class="panel">
        <h2 class="eyebrow">Pricing & Hours</h2>
        <div class="pricing">
          <div class="price-item"><strong>Day Pass</strong><br/>{{ dayPassPrice }}</div>
          <div class="price-item"><strong>Membership</strong><br/>{{ membershipPrice }}</div>
          <div class="price-item" style="grid-column:1/-1"><strong>Opening Hours</strong><br/>{{ openingHours }}</div>
        </div>
        {% if bookingLink %}<a class="cta" href="{{ bookingLink }}" target="_blank" rel="noopener noreferrer">Book / Official Site →</a>{% endif %}
      </article>
      {% include "components/VenueMap.njk" %}
    </section>
    {% include "components/RelatedVenues.njk" %}
  </main>
</body>
</html>
