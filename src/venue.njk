---
pagination:
  data: venues
  size: 1
  alias: item
permalink: "/{{ item.citySlug }}/{{ item.venue.slug | default(item.fileSlug) }}/"
---
{%- set v = item.venue -%}
{%- set seo = item.seo -%}
{%- set citySlug = item.citySlug -%}
{%- set venueSlug = v.slug | default(item.fileSlug) -%}
{%- set dipScore = v.score | default("Coming soon") -%}
{%- set audienceRating = v.audience_rating | default(v.audienceRating) | default(v.rating) | default("Not yet rated") -%}
{%- set rawRitualTags = v.ritual_tags | default(v.tags) | default(v.rituals) | default([]) -%}
{%- set ritualTags = [] -%}
{%- for tag in rawRitualTags -%}
  {%- set normalizedTag = tag.tag | default(tag.ritual_tag) | default(tag) -%}
  {%- if normalizedTag -%}
    {%- set ritualTags = ritualTags.concat([normalizedTag]) -%}
  {%- endif -%}
{%- endfor -%}
{%- set editorialSummary = v.editorial_summary | default(v.review) | default("Editorial summary coming soon.") -%}
{%- set dayPassPrice = v.day_pass_price | default(v.price) | default("—") -%}
{%- set membershipPrice = v.membership_price | default("—") -%}
{%- set openingHours = v.opening_hours | default(v.hours) | default("Hours unavailable") -%}
{%- set bookingLink = v.booking_link | default(v.booking_url) | default(v.website_url) -%}
{%- set latitude = v.latitude | default(v.lat) | default(v.coordinates.lat) -%}
{%- set longitude = v.longitude | default(v.lng) | default(v.coordinates.lng) -%}
{%- set instagramPosts = v.instagram_posts | default([]) -%}
{%- set related = [] -%}
{%- set ritualNeedles = ritualTags | join('|') | lower -%}
{%- for candidate in venues -%}
  {%- if candidate.citySlug == citySlug and (candidate.venue.slug | default(candidate.fileSlug)) != venueSlug -%}
    {%- set candidateVenue = candidate.venue -%}
    {%- set rawCandidateTags = candidateVenue.ritual_tags | default(candidateVenue.tags) | default(candidateVenue.rituals) | default([]) -%}
    {%- set candidateTags = [] -%}
    {%- for tag in rawCandidateTags -%}
      {%- set normalizedTag = tag.tag | default(tag.ritual_tag) | default(tag) -%}
      {%- if normalizedTag -%}
        {%- set candidateTags = candidateTags.concat([normalizedTag]) -%}
      {%- endif -%}
    {%- endfor -%}
    {%- set candidateTagBlob = candidateTags | join('|') | lower -%}
    {%- set hasSimilarRitual = ritualNeedles and candidateTagBlob and (ritualNeedles in candidateTagBlob or candidateTagBlob in ritualNeedles) -%}
    {%- if hasSimilarRitual or ritualTags.length == 0 -%}
      {%- set related = related.concat([candidate]) -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
<!DOCTYPE html>
<html lang="en">
  <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>{{ seo.title | default(v.name + " | Dip") }}</title>
    <meta name="description" content="{{ seo.description | default(editorialSummary | truncate(155, true)) }}" />
    <link rel="canonical" href="https://dipdays.com/{{ citySlug }}/{{ venueSlug }}/" />
    <meta property="og:title" content="{{ seo.title | default(v.name + ' Review | Dip') }}" />
    <meta property="og:description" content="{{ seo.description | default(editorialSummary | truncate(155, true)) }}" />
    <meta property="og:type" content="article" />
    <meta property="og:url" content="https://dipdays.com/{{ citySlug }}/{{ venueSlug }}/" />
    {% if seo.social_image %}<meta property="og:image" content="{{ seo.social_image | assetUrl }}" />{% endif %}
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json">
    {
      "@context":"https://schema.org",
      "@graph":[
        {
          "@type":"Place",
          "name":{{ v.name | json }},
          "url":{{ ("https://dipdays.com/" + citySlug + "/" + venueSlug + "/") | json }},
          {% if seo.social_image or v.hero_image %}"image":{{ (seo.social_image | default(v.hero_image) | assetUrl) | json }},{% endif %}
          "address":{"@type":"PostalAddress","addressLocality":{{ v.city | default('') | json }}},
          {% if latitude and longitude %}"geo":{"@type":"GeoCoordinates","latitude":{{ latitude | json }},"longitude":{{ longitude | json }}},{% endif %}
          "additionalType":"https://schema.org/WellnessFacility"
        },
        {
          "@type":"TouristAttraction",
          "name":{{ v.name | json }},
          "touristType":"Wellness traveler",
          "isPartOf":{{ v.city | default('') | json }}
        },
        {
          "@type":"WellnessFacility",
          "name":{{ v.name | json }},
          "description":{{ editorialSummary | truncate(220, true) | json }}
        }
      ]
    }
    </script>
    <link rel="preload" href="/fonts/syne-700.ttf" as="font" type="font/ttf" crossorigin/>
    <link rel="preload" href="/fonts/playfair-display-400-italic.ttf" as="font" type="font/ttf" crossorigin/>
    <link rel="stylesheet" href="/fonts/fonts.css"/>
    <style>
      :root{--ink:#101010;--muted:#6f6a63;--page:#f5f2eb;--card:#fffdf8;--line:#ded8cc;--teal:#0b7c78;--font-sans:'Syne',ui-sans-serif,system-ui,-apple-system,'Segoe UI',sans-serif;--font-serif:'Playfair Display',Georgia,'Times New Roman',serif;}
      *{box-sizing:border-box}
      body{margin:0;background:var(--page);color:var(--ink);font-family:var(--font-sans)}
      .shell{max-width:1220px;margin:0 auto;padding:24px 18px 70px}
      .back{display:inline-block;margin-bottom:16px;color:var(--teal);font-size:11px;letter-spacing:.14em;text-transform:uppercase;text-decoration:none;font-weight:700}
      .hero{display:grid;grid-template-columns:1.2fr .8fr;gap:18px}
      .hero-image{border:2px solid var(--ink);aspect-ratio:16/10;overflow:hidden;background:#d8d8d8}
      .hero-image img{width:100%;height:100%;object-fit:cover;display:block}
      .panel{background:var(--card);border:2px solid var(--ink);padding:18px}
      h1{margin:0;font-size:clamp(34px,4vw,56px);line-height:.92;letter-spacing:-.03em}
      .city{margin:8px 0 18px;color:var(--muted);font-family:var(--font-serif);font-style:italic}
      .ratings{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
      .metric{border:1px solid var(--line);padding:12px;background:#fff}
      .metric b{display:block;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
      .metric .value{font-size:24px;font-weight:700}
      .tooltip{border-bottom:1px dashed var(--muted);cursor:help}
      .tags{display:flex;flex-wrap:wrap;gap:8px}
      .tag{padding:7px 10px;background:#efe9dd;border:1px solid #d6cec0;font-size:11px;letter-spacing:.08em;text-transform:uppercase}
      .layout{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:18px}
      .eyebrow{margin:0 0 10px;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}
      .copy{margin:0;line-height:1.72;font-size:16px}
      .ritual-grid,.pricing{display:grid;grid-template-columns:1fr 1fr;gap:10px}
      .ritual-item,.price-item{border:1px solid var(--line);padding:10px;background:#fff}
      .gallery-wrap{margin-top:18px}
      .gallery-track{display:flex;gap:12px;overflow-x:auto;scroll-snap-type:x mandatory;padding-bottom:8px}
      .gallery-card{flex:0 0 min(76vw,470px);border:2px solid var(--ink);background:#111;scroll-snap-align:start;aspect-ratio:16/10;position:relative}
      .gallery-card img,.gallery-card iframe{width:100%;height:100%;display:block;border:0;object-fit:cover}
      .map-frame{border:2px solid var(--ink);height:320px;width:100%}
      .cards{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
      .card{background:#fff;border:1px solid var(--line);padding:12px;text-decoration:none;color:var(--ink)}
      .card b{display:block;margin-bottom:5px}
      .cta{display:inline-block;margin-top:12px;padding:10px 14px;background:#111;color:#fff;text-decoration:none;font-size:11px;letter-spacing:.12em;text-transform:uppercase}
      @media (max-width: 980px){
        .hero,.layout{grid-template-columns:1fr}
        .cards,.ratings,.ritual-grid,.pricing{grid-template-columns:1fr}
        .shell{padding:16px 12px 44px}
        .gallery-card{flex-basis:86vw}
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <a class="back" href="/#venue=/{{ citySlug }}/{{ venueSlug }}/">&#8592; Back to Dip directory</a>

      <section class="hero">
        <div class="hero-image" aria-label="Venue hero image">
          {% if v.hero_image %}<img src="{{ v.hero_image | assetUrl }}" alt="{{ v.name }} hero image" loading="eager" decoding="async" />{% endif %}
        </div>
        <article class="panel">
          <h1>{{ v.name }}</h1>
          <p class="city">{{ v.city | default(citySlug | replace('-', ' ')) }}</p>
          <div class="ratings">
            <div class="metric"><b><span class="tooltip" title="DipScore is Dip's editorial wellness scoring model based on ritual quality, design, and recovery value.">DipScore</span></b><div class="value">{{ dipScore }}</div></div>
            <div class="metric"><b><span class="tooltip" title="Audience Rating reflects community sentiment and public reviews.">Audience ★</span></b><div class="value">{{ audienceRating }}</div></div>
          </div>
          {% if ritualTags.length %}
            <p class="eyebrow" style="margin-bottom:8px">Ritual Tags</p>
            <div class="tags">
              {% for tag in ritualTags %}<span class="tag">{{ tag }}</span>{% endfor %}
            </div>
          {% elif v.best_for %}
            <p class="eyebrow" style="margin-bottom:8px">Ritual Tags</p>
            <div class="tags"><span class="tag">{{ v.best_for }}</span></div>
          {% endif %}
        </article>
      </section>

      <section class="gallery-wrap panel">
        <h2 class="eyebrow">Image Gallery</h2>
        <div class="gallery-track">
          {% if v.hero_image %}<article class="gallery-card"><img src="{{ v.hero_image | assetUrl }}" alt="{{ v.name }} hero" loading="lazy" decoding="async"/></article>{% endif %}
          {% for img in v.gallery_images | default([]) %}
            {%- set imgSrc = (img.image | default(img.src) | default(img.url) | default(img)) | assetUrl -%}
            {% if imgSrc %}<article class="gallery-card"><img src="{{ imgSrc }}" alt="{{ v.name }} photo {{ loop.index }}" loading="lazy" decoding="async"/></article>{% endif %}
          {% endfor %}
          {% for ig in instagramPosts %}
            {%- set igUrl = ig.embed_url | default(ig.url) | default(ig) -%}
            {% if igUrl %}<article class="gallery-card"><iframe src="{{ igUrl }}" title="Instagram post {{ loop.index }}" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe></article>{% endif %}
          {% endfor %}
        </div>
      </section>

      <section class="layout">
        <article class="panel">
          <h2 class="eyebrow">Editorial Summary</h2>
          <p class="copy">{{ editorialSummary }}</p>
        </article>
        <article class="panel">
          <h2 class="eyebrow">Ritual Experience</h2>
          <div class="ritual-grid">
            {% for ritual in [
              {"k":"sauna","i":"♨️","v":v.sauna},
              {"k":"steam room","i":"💨","v":v.steam_room},
              {"k":"cold plunge","i":"🧊","v":v.cold_plunge},
              {"k":"hammam","i":"🛁","v":v.hammam},
              {"k":"social space","i":"🫖","v":v.social_space},
              {"k":"food bar","i":"🥗","v":v.food_bar},
              {"k":"massage","i":"💆","v":v.massage}
            ] %}
              {% if ritual.v %}<div class="ritual-item">{{ ritual.i }} <strong>{{ ritual.k | title }}</strong><br/>{{ ritual.v }}</div>{% else %}<div class="ritual-item">{{ ritual.i }} <strong>{{ ritual.k | title }}</strong><br/>Not listed</div>{% endif %}
            {% endfor %}
          </div>
        </article>
      </section>

      <section class="layout">
        <article class="panel">
          <h2 class="eyebrow">Pricing & Hours</h2>
          <div class="pricing">
            <div class="price-item"><strong>Day Pass</strong><br/>{{ dayPassPrice }}</div>
            <div class="price-item"><strong>Membership</strong><br/>{{ membershipPrice }}</div>
            <div class="price-item" style="grid-column:1/-1"><strong>Opening Hours</strong><br/>{{ openingHours }}</div>
          </div>
          {% if bookingLink %}<a class="cta" href="{{ bookingLink }}" target="_blank" rel="noopener noreferrer">Book / Official Site →</a>{% endif %}
        </article>

        <article class="panel">
          <h2 class="eyebrow">Map</h2>
          {% if latitude and longitude %}
            <iframe class="map-frame" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="https://maps.google.com/maps?q={{ latitude }},{{ longitude }}&z=14&output=embed" title="{{ v.name }} location"></iframe>
          {% else %}
            <p class="copy">Map coordinates are not yet published for this venue.</p>
          {% endif %}
        </article>
      </section>

      {% if related.length %}
      <section class="panel" style="margin-top:18px">
        <h2 class="eyebrow">Related Venues</h2>
        <div class="cards">
          {% for rv in (related | sort(false, false, 'venue.score')) %}
            {% if loop.index <= 4 %}
              <a class="card" href="/{{ rv.citySlug }}/{{ rv.venue.slug | default(rv.fileSlug) }}/">
                <b>{{ rv.venue.name }}</b>
                <span>{{ rv.venue.city | default(rv.citySlug | replace('-', ' ')) }} · DipScore {{ rv.venue.score | default('—') }}</span>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </section>
      {% endif %}
    </main>
  </body>
</html>
