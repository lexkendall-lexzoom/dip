---
pagination:
  data: venues
  size: 1
  alias: item
permalink: "/{{ item.citySlug }}/{{ item.venue.slug | default(item.fileSlug) }}/"
---
{%- set v = item.venue -%}
{%- set seo = item.seo -%}
{%- set citySlug = item.citySlug -%}
<!DOCTYPE html>
<html lang="en">
  <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>{{ seo.title | default(v.name + " | Dip") }}</title>
    <meta name="description" content="{{ seo.description | default('') }}" />
    <link rel="canonical" href="https://dipdays.com/{{ citySlug }}/{{ v.slug | default(item.fileSlug) }}/" />
    <meta property="og:title" content="{{ seo.title | default(v.name + ' Review | Dip') }}" />
    <meta property="og:description" content="{{ seo.description | default('') }}" />
    <meta property="og:type" content="article" />
    <meta property="og:url" content="https://dipdays.com/{{ citySlug }}/{{ v.slug | default(item.fileSlug) }}/" />
    {% if seo.social_image %}<meta property="og:image" content="{{ seo.social_image }}" />{% endif %}
    <meta name="twitter:card" content="summary_large_image" />
    {% if v.website_url %}<script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"{{ v.name }}","url":"{{ v.website_url }}","address":{"@type":"PostalAddress","addressLocality":"{{ v.city }}"},"areaServed":"{{ v.city }}"}</script>{% endif %}
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Playfair+Display:ital,wght@0,500;1,400;1,500&display=swap"/>
    <style>
          :root{--ink:#111;--page:#f3f0e8;--card:#fff;--mist:#d8d4ca;--teal:#0b7c78;--font-sans:'Syne',ui-sans-serif,system-ui,-apple-system,'Segoe UI',sans-serif;--font-serif:'Playfair Display',Georgia,serif;}
          *{box-sizing:border-box}
          body{margin:0;background:var(--page);color:var(--ink);font-family:var(--font-sans)}
          .shell{max-width:1240px;margin:0 auto;padding:30px 24px 64px}
          .back{display:inline-block;margin-bottom:16px;color:var(--teal);font-size:11px;letter-spacing:.14em;text-transform:uppercase;text-decoration:none;font-weight:700}
          .hero-media{position:relative;border:2px solid var(--ink);aspect-ratio:16/9;overflow:hidden;background:#ddd}
          .hero-media::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.2),rgba(0,0,0,.45));pointer-events:none}
          .hero-media > img{width:100%;height:100%;object-fit:cover;display:block}
          .chips{position:absolute;left:14px;top:14px;display:flex;gap:8px;flex-wrap:wrap;z-index:3}
          .chip{background:rgba(17,17,17,.88);color:#fff;padding:6px 10px;font-size:10px;letter-spacing:.12em;text-transform:uppercase}
          .logo-headline{position:absolute;inset:auto 20px 24px 20px;z-index:3;display:flex;justify-content:center;align-items:center;min-height:82px;padding:10px;background:rgba(255,255,255,.94);border:2px solid #111;box-shadow:6px 6px 0 rgba(0,0,0,.2)}
          .logo-headline img{max-height:54px;max-width:min(88%,520px);width:auto;height:auto;object-fit:contain;filter:contrast(1.05)}
          .details-grid{display:grid;grid-template-columns:.85fr 1.25fr;gap:20px;margin-top:20px}
          .box{background:var(--card);border:2px solid var(--ink);padding:20px}
          .fieldbox{min-height:270px}
          .reviewbox{min-height:340px}
          h1{margin:0 0 10px;font-size:clamp(32px,3.4vw,52px);line-height:.95;letter-spacing:-.03em}
          .sub{font-family:var(--font-serif);font-style:italic;color:#555;margin:0 0 14px}
          .facts{display:grid;grid-template-columns:1fr 1fr;gap:10px}
          .fact{border:1px solid var(--mist);background:#faf8f3;padding:10px;min-height:72px}
          .fact b{display:block;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:#666;margin-bottom:4px}
          .fact.wide{grid-column:1 / -1;min-height:60px}
          .cta{display:inline-block;margin-top:14px;padding:10px 14px;background:#111;color:#fff;text-decoration:none;font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:700}
          .review-title,.carousel-title{margin:0 0 10px;font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:#666}
          .desc{line-height:1.75;margin:0;font-size:16px}
          .carousel-box{margin-top:16px}
          .carousel{position:relative}
          .carousel-track{display:flex;overflow:hidden;border:2px solid var(--ink);background:#111;aspect-ratio:16/9}
          .slide{min-width:100%;height:100%;position:relative;display:flex;align-items:center;justify-content:center;color:#fff;text-transform:uppercase;letter-spacing:.08em}
          .slide img{width:100%;height:100%;object-fit:cover;display:block}
          .slide.placeholder{background:linear-gradient(135deg,#20403f,#3e6662);font-size:12px}
          .controls{display:flex;justify-content:space-between;align-items:center;margin-top:10px}
          .btn{background:#111;color:#fff;border:none;padding:9px 12px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;cursor:pointer}
          .dots{display:flex;gap:8px}
          .dot{width:9px;height:9px;border-radius:50%;background:#c7c2b8;border:none;cursor:pointer}
          .dot.active{background:#0b7c78}
          @media (max-width: 980px){
                  .details-grid{grid-template-columns:1fr}
                  .fieldbox,.reviewbox{min-height:auto}
                  .desc{font-size:15px}
                  .logo-headline{min-height:64px;inset:auto 14px 14px 14px}
                  .logo-headline img{max-height:40px}
          }
        </style>
  </head>
  <body>
    <main class="shell">
        <a class="back" href="/{{ citySlug }}/">&#8592; Back to {{ v.city | default(citySlug | replace("-", " ") | title) }} guide</a>
        <section class="hero-media" aria-label="Venue hero image">
              {% if v.hero_image %}<img src="{{ v.hero_image }}" alt="{{ v.name }} hero image" loading="eager"/>{% endif %}
              <div class="chips">
                {% if v.best_for %}<span class="chip">{{ v.best_for | truncate(30, true) }}</span>{% endif %}
                <span class="chip">{{ citySlug | replace("-", " ") | upper | truncate(3, false, "") }} Score {{ v.score | default("Coming soon") }}</span>
              </div>
              {% if v.website_url %}
              <div class="logo-headline">
                      <img src="{{ v.website_url }}/favicon.ico" alt="{{ v.name }} logo sourced from official website domain" loading="lazy" referrerpolicy="no-referrer" onerror="this.closest('.logo-headline').remove()"/>
              </div>
              {% endif %}
        </section>
        <section class="details-grid">
              <article class="box fieldbox">
                      <h1>{{ v.name }}</h1>
                    {% if v.subtitle %}<p class="sub">{{ v.subtitle }}</p>{% endif %}
                    <div class="facts">
                            {% if v.neighborhood %}<div class="fact"><b>Neighborhood</b>{{ v.neighborhood }}</div>{% endif %}
                            {% if v.price %}<div class="fact"><b>Price</b>{{ v.price }}</div>{% endif %}
                            <div class="fact"><b>Score</b>{{ v.score | default("Coming soon") }}</div>
                            {% if v.date_reviewed %}<div class="fact"><b>Date reviewed</b>{{ v.date_reviewed }}</div>{% endif %}
                            {% if v.hours %}<div class="fact wide"><b>Hours</b>{{ v.hours }}</div>{% endif %}
                    </div>
                    {% if v.best_for %}<p style="margin:12px 0 0"><strong>Best for:</strong> {{ v.best_for }}</p>{% endif %}
                    {% if v.website_url %}<a class="cta" href="{{ v.website_url }}" target="_blank" rel="noopener noreferrer">Official Website &rarr;</a>{% endif %}
              </article>
            <article class="box reviewbox">
                  <h2 class="review-title">Dip Review</h2>
                  <p class="desc">{{ v.review | default("Review coming soon.") }}</p>
            </article>
        </section>
      {% if v.gallery_images and v.gallery_images.length > 0 %}
      <section class="box carousel-box">
          <h2 class="carousel-title">Venue Photos</h2>
          <div class="carousel" data-carousel>
                <div class="carousel-track" data-track>
                  {% for img in v.gallery_images %}
                        <div class="slide"><img src="{{ img }}" alt="{{ v.name }} photo {{ loop.index }}" loading="lazy"/></div>
                  {% endfor %}
                </div>
                <div class="controls">
                        <button class="btn" type="button" data-prev>&#8592; Prev</button>
                        <div class="dots">
                          {% for img in v.gallery_images %}
                                  <button class="dot{% if loop.first %} active{% endif %}" type="button" data-dot="{{ loop.index0 }}" aria-label="Slide {{ loop.index }}"></button>
                          {% endfor %}
                        </div>
                        <button class="btn" type="button" data-next>Next &#8594;</button>
                </div>
          </div>
      </section>
      {% endif %}
    </main>
  <script>
    (function() {
        document.querySelectorAll('[data-carousel]').forEach((carousel) => {
              const track = carousel.querySelector('[data-track]');
              const slides = Array.from(track.children);
              const dots = Array.from(carousel.querySelectorAll('[data-dot]'));
              let index = 0;
              function render() {
                      track.style.transform = `translateX(-${index * 100}%)`;
                      track.style.transition = 'transform 260ms ease';
                      dots.forEach((d, i) => d.classList.toggle('active', i === index));
              }
              carousel.querySelector('[data-prev]').addEventListener('click', () => { index = (index - 1 + slides.length) % slides.length; render(); });
              carousel.querySelector('[data-next]').addEventListener('click', () => { index = (index + 1) % slides.length; render(); });
              dots.forEach((dot, i) => dot.addEventListener('click', () => { index = i; render(); }));
        });
    })();
  </script>
  </body>
</html>
