---
pagination:
  data: directory.cityPages
  size: 1
  alias: page
permalink: "{{ page.path }}"
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{{ page.name }} Bathhouses, Saunas & Cold Plunges | DipDays</title>
  <meta name="description" content="{{ page.intro }}" />
  {% if not page.indexable %}<meta name="robots" content="noindex,follow" />{% endif %}
</head>
<body>
  <h1>{{ page.name }}</h1>
  <p>{{ page.intro }}</p>

  <h2>Featured venues</h2>
  <ul>
    {% for venue in page.featuredVenues %}
    <li><a href="{{ venue.path }}">{{ venue.name }}</a> · {{ venue.primary_category }}</li>
    {% endfor %}
  </ul>

  <h2>Top categories in {{ page.name }}</h2>
  <ul>
    {% for category in page.topCategories %}
    <li>
      <a href="{{ category.path }}">{{ category.name }}</a>
      ({{ category.count }})
      {% if not category.indexable %}<small>noindex</small>{% endif %}
    </li>
    {% endfor %}
  </ul>

  <h2>Relevant amenities</h2>
  <ul>
    {% for amenity in page.relevantAmenities %}
    <li>
      <a href="{{ amenity.path }}">{{ amenity.name }}</a>
      ({{ amenity.count }})
      {% if not amenity.indexable %}<small>noindex</small>{% endif %}
    </li>
    {% endfor %}
  </ul>
</body>
</html>
